# ════════════════════════════════════════════════════════════════════
# Boxing Center — Phone Bot
# Copier ce fichier en  .env  et remplir les valeurs
# NE JAMAIS committer le fichier  .env  (contient les vraies clés)
# ════════════════════════════════════════════════════════════════════

# ── Serveur ───────────────────────────────────────────────────────
PORT=3000
# URL publique du serveur (ngrok en dev, domaine en prod)
# Utilisée pour construire les action= des webhooks Twilio
BASE_URL=https://xxxx-xxxx-xxxx.ngrok-free.app

# ── Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+33XXXXXXXXX        # Numéro Twilio voix + SMS
TWILIO_WHATSAPP_NUMBER=+14155238886     # Sandbox WhatsApp Twilio (ou votre numéro WA Business)

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Transferts ────────────────────────────────────────────────────
# Numéros vers lesquels le bot transfère les appels
TRANSFER_ACCUEIL=+33XXXXXXXXX           # Accueil / Conseiller principal
TRANSFER_ADMIN=+33XXXXXXXXX             # Service administratif / Compta
TRANSFER_COMPETITION=+33XXXXXXXXX       # Responsable compétition

# ── Liens envoyés par SMS ─────────────────────────────────────────
BOXING_WEBSITE=https://boxingcenter.fr
LINK_HORAIRES=https://boxingcenter.fr/horaires
LINK_TARIFS=https://boxingcenter.fr/tarifs
LINK_ESSAI=https://boxingcenter.fr/essai-gratuit
LINK_INSCRIPTION=https://boxingcenter.fr/inscription
LINK_PLANNING=https://boxingcenter.fr/planning
LINK_COMPETITION=https://boxingcenter.fr/competition

# ── Options ───────────────────────────────────────────────────────
BOT_DRY_RUN=false    # true = aucun SMS envoyé, aucun transfert réel
DEBUG=false
