# Boxing Center — Phone Bot (Telnyx)
# Copier ce fichier en  .env
# ════════════════════════════════════════════════════════════════════

PORT=3000
BASE_URL=http://localhost:3000

# ── Telnyx ────────────────────────────────────────────────────────
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Transferts ────────────────────────────────────────────────────
TRANSFER_ACCUEIL=+33XXXXXXXXX
TRANSFER_ADMIN=+33XXXXXXXXX
TRANSFER_COMPETITION=+33XXXXXXXXX

# ── Liens SMS ─────────────────────────────────────────────────────
BOXING_WEBSITE=https://boxingcenter.fr
LINK_HORAIRES=https://boxingcenter.fr/horaires
LINK_TARIFS=https://boxingcenter.fr/tarifs
LINK_ESSAI=https://boxingcenter.fr/essai-gratuit
LINK_INSCRIPTION=https://boxingcenter.fr/inscription
LINK_PLANNING=https://boxingcenter.fr/planning
LINK_COMPETITION=https://boxingcenter.fr/competition

BOT_DRY_RUN=false
DEBUG=false
