# Boxing Center — Phone Bot
# Bot-hosting : copier ce fichier vers /home/container/.env
# Ne jamais committer le .env ni env.bothosting avec les vraies clés.
#
# ─── Port (obligatoire sur bot-hosting) ───────────────────────────────────────
SERVER_PORT=20XXX
PORT=20XXX

# ─── URL publique ─────────────────────────────────────────────────────────────
BASE_URL=https://prem-eu5.bot-hosting.cloud:20XXX

# ─── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+33XXXXXXXXX
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Transferts ─────────────────────────────────────────────────────────────
TRANSFER_ACCUEIL=+33XXXXXXXXX
TRANSFER_ADMIN=+33XXXXXXXXX
TRANSFER_COMPETITION=+33XXXXXXXXX

# ─── Liens SMS ──────────────────────────────────────────────────────────────
BOXING_WEBSITE=https://boxingcenter.fr
LINK_HORAIRES=https://boxingcenter.fr/horaires
LINK_TARIFS=https://boxingcenter.fr/tarifs
LINK_ESSAI=https://boxingcenter.fr/essai-gratuit
LINK_INSCRIPTION=https://boxingcenter.fr/inscription
LINK_PLANNING=https://boxingcenter.fr/planning
LINK_COMPETITION=https://boxingcenter.fr/competition

# ─── Options ────────────────────────────────────────────────────────────────
BOT_DRY_RUN=false
DEBUG=false
